  "required_plugins": [
    "GameFeatures",
    "ModularGameplay"
  ],
  "owned_umbrellas": [
    "game_features"
  ],
  "owned_tools": [
    "add_game_feature_action_add_components",
    "add_game_feature_action",
    "list_game_feature_actions",
    "list_game_features",
    "set_game_feature_state"
  ],
  "umbrella_docs": {
    "game_features": "Docs/game_features.uecpdat"
  }
}
