    "set_gameplay_effect_stacking",
    "set_gameplay_effect_period",
    "set_ability_cost",
    "set_ability_cooldown",
    "get_gameplay_effect_summary",
    "get_attribute_set_summary",
    "remove_gameplay_effect_modifier",
    "list_gameplay_abilities",
    "set_gameplay_effect_tags",
    "set_modifier_magnitude",
    "set_ability_net_config",
    "add_ability_trigger",
    "gas_get_attribute_values",
    "gas_get_active_effects",
    "gas_get_granted_abilities",
