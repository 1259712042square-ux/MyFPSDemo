  "extension_id": "Blueprint",
  "display_name": "Blueprint Authoring",
  "description": "The full Blueprint authoring surface: class creation + compile, variables, functions, event dispatchers, components, graph build/clear/inspect, place/connect/remove nodes, set pin defaults, timelines, comments, CDO + interface + compare. Includes the auto-repair + fuzzy-handle-resolution + layout pipeline that powers build_blueprint_graph. Also owns the component umbrella (actor/blueprint component config) and the gameplay_tags umbrella (project tag table + tag containers on blueprints).",
  "category": "Blueprint",
  "catalog_blurb": "Blueprint authoring + component config + gameplay tags.",
  "required_module_name": "UECPBlueprintExt",
